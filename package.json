{
  "name": "@kutsan/eslint-config",
  "version": "2.0.3",
  "description": "Eslint configuration for my projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kutsan/eslint-config.git"
  },
  "license": "MIT",
  "author": "Kutsan Kaplan <me@kutsan.dev> (https://kutsan.dev)",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "check": "pnpm run check:lint && pnpm run check:format && pnpm run check:format",
    "check:format": "prettier --check .",
    "check:lint": "eslint --max-warnings=0 --flag unstable_native_nodejs_ts_config",
    "check:types": "tsc --noEmit",
    "format": "prettier --write --list-different .",
    "prepare": "husky"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-config-love": "^153.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-yml": "^3.3.1",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.58.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@kutsan/prettier-config": "^1.2.0",
    "@kutsan/typescript-config": "^2.1.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "warn"
    }
  }
}
